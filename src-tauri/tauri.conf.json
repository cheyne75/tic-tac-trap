{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tic Tac Trap",
  "version": "0.1.0",
  "identifier": "com.tictactrap.game",
  "build": {
    "beforeBuildCommand": "mkdir -p dist && cp index.html dist/index.html",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "Tic Tac Trap",
        "width": 700,
        "height": 780,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
